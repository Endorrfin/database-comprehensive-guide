{
  "name": "database-comprehensive-guide",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://endorrfin.github.io/database-comprehensive-guide/",
  "description": "Deep, interactive, bilingual (EN/UA) guide to how databases actually work.",
  "author": "Vasyl Krupka",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "gen:meta": "tsx scripts/gen-meta.ts",
    "check:data": "tsx scripts/check-data.ts",
    "check:ua": "tsx scripts/check-ua.ts",
    "test:btree": "tsx scripts/test-btree.ts",
    "test:lsm": "tsx scripts/test-lsm.ts",
    "test:mvcc": "tsx scripts/test-mvcc.ts",
    "test:planner": "tsx scripts/test-planner.ts",
    "test:sharding": "tsx scripts/test-sharding.ts",
    "test": "npm run test:btree && npm run test:lsm && npm run test:mvcc && npm run test:planner && npm run test:sharding",
    "smoke": "tsx --tsconfig tsconfig.app.json scripts/smoke.ts",
    "truth": "node scripts/node-truth-sharding.mjs && node scripts/node-truth-lsm.mjs",
    "verify": "npm run typecheck && npm run lint && npm run check:data && npm run check:ua && npm run test && npm run smoke && npm run build"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0"
  }
}
